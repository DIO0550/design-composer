{
  "permissions": {
    "allow": [
      "Bash(pnpm test:run)",
      "Bash(pnpm test:run *)",
      "Bash(pnpm test)",
      "Bash(pnpm test *)",
      "Bash(pnpm run build)",
      "Bash(pnpm run typecheck)",
      "Bash(pnpm run lint)",
      "Bash(pnpm exec vitest)"
    ]
  },
  "extraKnownMarketplaces": {
    "d-market-rust": {
      "source": {
        "source": "github",
        "repo": "DIO0550/d-market-rust"
      }
    },
    "d-market-typescript": {
      "source": {
        "source": "github",
        "repo": "DIO0550/d-market-typescript"
      }
    },
    "d-market-react": {
      "source": {
        "source": "github",
        "repo": "DIO0550/d-market-react"
      }
    },
    "d-market-spec": {
      "source": {
        "source": "github",
        "repo": "DIO0550/d-market-spec"
      }
    },
    "d-market-git": {
      "source": {
        "source": "github",
        "repo": "DIO0550/d-market-git"
      },
      "autoUpdate": true
    },
    "d-market-code-review": {
      "source": {
        "source": "github",
        "repo": "DIO0550/d-market-code-review"
      }
    },
    "d-market-doc-gen": {
      "source": {
        "source": "github",
        "repo": "DIO0550/d-market-doc-gen"
      }
    },
    "d-market-statusline": {
      "source": {
        "source": "github",
        "repo": "DIO0550/d-market-statusline"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-npx.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/pre-push-typecheck.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/pre-push-lint.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/pre-push-test-rules.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-lint-suppress.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/post-edit-lint.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/check-test-rules.sh\""
          }
        ]
      }
    ]
  }
}
